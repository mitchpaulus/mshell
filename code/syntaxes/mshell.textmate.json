{
    "scopeName": "source.mshell",
    "fileTypes": [
        "mshell"
    ],
    "patterns": [
        {
            "name": "comment.line.number-sign",
            "match": "#.*$"
        },
        {
            "name": "constant.language.bool",
            "match": "\\b(true|false)\\b"
        },
        {
            "name": "string.quoted.single.mshell",
            "begin": "'",
            "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.mshell" } },
            "end": "'",
            "endCaptures": { "0": { "name": "punctuation.definition.string.end.mshell" } }
        },
        {
            "name": "string.quoted.other.path.mshell",
            "begin": "`",
            "end": "`"
        },
        {
            "include": "#string_interpolated"
        },
        {
            "include": "#string_double"
        },
        {
            "name": "variable.other.set",
            "match": "\\$[a-zA-Z0-9_]+!"
        },
        {
            "name": "variable.other.envretrieve",
            "match": "\\$[a-zA-Z0-9_]+"
        },
        {
            "name": "variable.other.retreive.mshell",
            "match": "[a-zA-Z0-9_]+!"
        },
        {
            "name": "variable.other.set.mshell",
            "match": "@[a-zA-Z0-9_]+"
        },
        {
            "name": "keyword.control.mshell",
            "match": "else\\*|\\*if"
        },
        {
            "name": "keyword.control.mshell",
            "match": "\\b(def|end|if|iff|loop|read|str|break|continue|else|match|enum|type)\\b"
        },
        {
            "name": "keyword.operator.word.mshell",
            "match": "\\b(and|or|not)\\b"
        },
        {
            "name": "keyword.other.mshell",
            "match": "\\bsoe\\b"
        },
        {
            "name": "storage.type.mshell",
            "match": "\\b(int|float|bool)\\b"
        },
        {
            "name": "constant.numeric.integer.hex.mshell",
            "match": "\\b0[xX][0-9A-Fa-f]+\\b"
        },
        {
            "name": "constant.numeric.integer.octal.mshell",
            "match": "\\b0[oO][0-7]+\\b"
        },
        {
            "name": "constant.numeric.integer.binary.mshell",
            "match": "\\b0[bB][01]+\\b"
        },
        {
            "name": "constant.numeric.float.mshell",
            "match": "\\b\\d+\\.\\d*(?:[eE][+-]?\\d+)?\\b"
        },
        {
            "name": "constant.numeric.integer.mshell",
            "match": "\\b\\d+(?:[eE][+-]?\\d+)?\\b"
        }
    ],
    "repository": {
        "string_double": {
            "name": "string.quoted.double.mshell",
            "begin": "\"",
            "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.mshell" } },
            "end": "\"",
            "endCaptures": { "0": { "name": "punctuation.definition.string.end.mshell" } },
            "patterns": [
                { "include": "#escape_simple" }
            ]
        },
        "string_interpolated": {
            "name": "string.quoted.double.interpolated.mshell",
            "begin": "\\$\"",
            "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.mshell" } },
            "end": "\"",
            "endCaptures": { "0": { "name": "punctuation.definition.string.end.mshell" } },
            "patterns": [
                { "include": "#interpolation" },
                { "include": "#escape_format" }
            ]
        },
        "interpolation": {
            "name": "meta.interpolation.mshell",
            "begin": "\\{",
            "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.mshell" } },
            "end": "\\}",
            "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.mshell" } },
            "patterns": [
                { "include": "$self" }
            ]
        },
        "escape_simple": {
            "name": "constant.character.escape.mshell",
            "match": "\\\\[entr\"\\\\]"
        },
        "escape_format": {
            "name": "constant.character.escape.mshell",
            "match": "\\\\[entr\"\\\\{]"
        }
    }
}
