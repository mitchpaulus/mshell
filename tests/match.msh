# Value matching - string
"hello" match
    "hello" : drop "greeting" wl,
    "bye"   : drop "farewell" wl,
    _       : drop "unknown" wl,
end

# Outer variable access and subject on stack
1 outerVariable!
10 match
    int : @outerVariable + str wl,
    _   : drop "Not found" wl,
end

# Value matching - integer
42 match
    1  : drop "one" wl,
    42 : drop "forty-two" wl,
    _  : drop "other" wl,
end

# Value matching - boolean
true match
    true  : drop "is true" wl,
    false : drop "is false" wl,
end

# Type matching - int
42 match
    int : drop "integer" wl,
    str : drop "string" wl,
    _   : drop "other" wl,
end

# Type matching - str
"hello" match
    int : drop "integer" wl,
    str : drop "string" wl,
    _   : drop "other" wl,
end

# Type matching - float
3.14 match
    int   : drop "integer" wl,
    float : drop "float" wl,
    _     : drop "other" wl,
end

# Type matching - bool
false match
    bool : drop "boolean" wl,
    _    : drop "other" wl,
end

# Type matching - list
[1 2 3] match
    list : drop "list" wl,
    _    : drop "other" wl,
end

# Type matching - path
`/tmp/test` match
    path : drop "path" wl,
    _    : drop "other" wl,
end

# Type matching - date
2025-01-01 match
    date : drop "date" wl,
    _    : drop "other" wl,
end

# Type matching - quotation
(1 2 +) match
    quotation : drop "quotation" wl,
    _         : drop "other" wl,
end

# Type matching - maybe
"hello" just match
    maybe : drop "maybe" wl,
    _     : drop "other" wl,
end

# Type matching - binary
"hello" utf8Bytes match
    binary : drop "binary" wl,
    _      : drop "other" wl,
end

# Type matching - dict
{ "a": 1 } match
    dict : drop "dict" wl,
    _    : drop "other" wl,
end

# Wildcard matching
"anything" match
    _ : drop "wildcard" wl,
end

# Trailing comma is optional (last arm)
99 match
    99 : drop "ninety-nine" wl
end

# Match with body that pushes to stack (subject replaced)
10 match
    10 : drop "ten",
    _  : drop "not ten",
end
wl

# Single quote string matching
'world' match
    'hello' : drop "hi" wl,
    'world' : drop "globe" wl,
    _       : drop "?" wl,
end

# Maybe destructuring - just (subject stays on stack, drop it)
"value" just match
    just v : drop @v wl,
    none   : drop "none" wl,
end

# Maybe destructuring - none
none match
    just v : drop @v wl,
    none   : drop "got none" wl,
end

# Maybe destructuring - just with wildcard
"ignored" just match
    just _ : drop "just something" wl,
    none   : drop "none" wl,
end

# List destructuring - exact (subject stays on stack, drop it)
[1 2 3] match
    [a b c] : drop @b str wl,
    _       : drop "other" wl,
end

# List destructuring - empty
[] match
    []  : drop "empty list" wl,
    _   : drop "not empty" wl,
end

# List destructuring - spread
[1 2 3 4 5] match
    [head ...tail] : drop @head str wl,
    _              : drop "other" wl,
end

# List destructuring - wildcard in list
[10 20 30] match
    [_ middle _] : drop @middle str wl,
    _            : drop "other" wl,
end

# Dict destructuring (subject stays on stack, drop it)
{ 'name': "Alice", 'age': 30 } match
    { 'name': n, 'age': a } : drop [@n " is " @a str] "" join wl,
    _                       : drop "missing fields" wl,
end

# Dict destructuring - missing key no match
{ 'name': "Bob" } match
    { 'name': n, 'age': a } : drop @n wl,
    { 'name': n }           : drop [@n " (no age)"] "" join wl,
    _                       : drop "other" wl,
end

# Dict destructuring - extra keys is fine for match
{ 'name': "Charlie", 'age': 25, 'city': "NY" } match
    { 'name': n, 'age': a } : drop [@n " is " @a str] "" join wl,
    _                       : drop "missing fields" wl,
end
