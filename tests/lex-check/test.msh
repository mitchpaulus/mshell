false anyFail!

"*.msh" glob (`test.msh` !=) filter
each.
    f!
    $"{@f}.stdout" isFile if
        ['mshell' '--lex' @f] * ; output!
        @output $"{@f}.stdout" readFile = if
            $"{@f}: PASS" wl
        else
            $"{@f}: FAIL" wl
            ['git' 'diff' @output psub $"{@f}.stdout"];
            true anyFail!
        end
    else
        $"{@f}: FAIL, no .stdout file" wl true anyFail!
    end
end


@anyFail if 1 else 0 end exit
