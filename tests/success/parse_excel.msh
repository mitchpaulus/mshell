`excel_test_file.xlsx` parseExcel wb!

@wb keys each. k!
    $"=== {@k} ===" wl
    @wb @k get? 1 enumerateN each.
        # 2unpack row!, rowNum!
        row!
        @row :item? 1 enumerateN each.
            col!
            @col :item? cell!
            # 2unpack cell!, colNum!
            $"{@row :index?}:{@col :index?}:{@cell typeof}|{@cell str}" wl
        end
    "---" wl
    end
end
